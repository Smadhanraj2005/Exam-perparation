function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

function goBack() {
  state = {
    exam: '', topics: [], overviewData: null, questions: [],
    answeredQ: {}, chatHistory: [], progress: { total:0, correct:0, byTopic:{} },
    activeTab: 'overview'
  };
  showScreen('landing');
  document.getElementById('examInput').value = '';
}

function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

function escapeHtml(t) {
  return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function markdownToHtml(md) {
  let h = md;
  h = h.replace(/```(\w*)\n([\s\S]*?)```/g, '<pre><code>$2</code></pre>');
  h = h.replace(/`([^`]+)`/g, '<code>$1</code>');
  h = h.replace(/^### (.+)$/gm, '<h4>$1</h4>');
  h = h.replace(/^## (.+)$/gm, '<h3>$1</h3>');
  h = h.replace(/^# (.+)$/gm, '<h2>$1</h2>');
  h = h.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  h = h.replace(/\*(.+?)\*/g, '<em>$1</em>');
  h = h.replace(/^---$/gm, '<hr>');
  h = h.replace(/^> (.+)$/gm, '<blockquote>$1</blockquote>');
  // Lists
  h = h.replace(/^(\d+)\. (.+)$/gm, '<li>$2</li>');
  h = h.replace(/^[-*] (.+)$/gm, '<li>$1</li>');
  h = h.replace(/(<li>.*<\/li>\n?)+/g, m => {
    if (/^\d/.test(m)) return `<ol>${m}</ol>`;
    return `<ul>${m}</ul>`;
  });
  // Paragraphs
  h = h.split('\n\n').map(para => {
    para = para.trim();
    if (!para) return '';
    if (/^<(h[2-4]|ul|ol|li|pre|blockquote|hr)/.test(para)) return para;
    return `<p>${para.replace(/\n/g, '<br>')}</p>`;
  }).join('');
  return h;
}
